# Configuración de Base de Datos PostgreSQL
# Copia este archivo a .env y configura tus credenciales

DB_HOST=localhost
DB_PORT=5432
DB_NAME=datajob_db
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# Configuración de Logging (opcional)
LOG_LEVEL=INFO

# Configuración de Pipeline (opcional)
CHUNK_SIZE=50000
